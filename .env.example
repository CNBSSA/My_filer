# Mai Filer — example environment
# Copy to .env for local dev. Never commit secrets.

# ---- App ----
APP_ENV=development
APP_NAME=mai-filer-api
APP_PORT=8000
LOG_LEVEL=INFO

# ---- Anthropic (Claude API) ----
# Opus 4.7 for Mai Filer orchestration, Sonnet 4.6 for tools, Haiku 4.5 for cheap tasks.
ANTHROPIC_API_KEY=
CLAUDE_MODEL_ORCHESTRATOR=claude-opus-4-7
CLAUDE_MODEL_TOOLS=claude-sonnet-4-6
CLAUDE_MODEL_CHEAP=claude-haiku-4-5-20251001

# ---- Database ----
DATABASE_URL=postgresql+psycopg://mai:mai@localhost:5432/mai_filer
REDIS_URL=redis://localhost:6379/0

# ---- Celery (P6.4 / P6.5) ----
# Default is OFF: all submissions run inline on the request thread. Flip
# CELERY_ENABLED=true AND run a `celery -A app.celery_app worker` process
# once Redis is provisioned. CELERY_TASK_EAGER=true forces tasks to run
# synchronously regardless (tests + preview envs without a worker).
CELERY_ENABLED=false
CELERY_TASK_EAGER=false
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- Object storage (dev: MinIO; prod: Nigerian S3-compatible) ----
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=mai-filer-dev
STORAGE_REGION=ng-lagos-1

# ---- NRS Gateway (sandbox) ----
NRS_BASE_URL=https://api.nrs.gov.ng/v1
NRS_CLIENT_ID=
NRS_CLIENT_SECRET=
NRS_BUSINESS_ID=

# ---- Identity aggregator (Dojah default; Seamfix / Prembly swappable) ----
IDENTITY_AGGREGATOR=dojah
DOJAH_API_KEY=
DOJAH_APP_ID=
SEAMFIX_API_KEY=
PREMBLY_API_KEY=

# ---- Encryption ----
# 32-byte key (base64) used for encrypting NIN ciphertext in the vault column.
NIN_VAULT_KEY=
NIN_HASH_SALT=

# ---- Auth / JWT ----
JWT_SECRET=
JWT_ISSUER=mai-filer
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# ---- CORS ----
# Comma-separated origins allowed to hit the API. Include the web service's
# public URL in production (e.g. Railway-provided https URL).
CORS_ALLOW_ORIGINS=http://localhost:3000

# ---- API Authentication ----
# Shared secret used by the FastAPI backend to authenticate all API requests.
# Must match NEXT_PUBLIC_API_TOKEN in the Next.js web app.
API_TOKEN=

# Next.js web app reads this to set the Authorization: Bearer header on all API calls.
NEXT_PUBLIC_API_TOKEN=
